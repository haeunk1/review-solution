{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "백엔드 실행",
            "type": "shell",
            "command": "uvicorn app.main:app --reload --host 0.0.0.0 --port 8081",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "group": "servers",
                "panel": "dedicated",
                "reveal": "always"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "프론트엔드 실행",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "presentation": {
                "group": "servers",
                "panel": "dedicated",
                "reveal": "always"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "전체 서버 실행",
            "dependsOn": ["백엔드 실행", "프론트엔드 실행"],
            "dependsOrder": "parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
